# Databricks notebook source
# Cell 1 - ADLS Connection
storage_account_name = "healthcaredlspaw"

storage_account_key = dbutils.secrets.get(
    scope="healthcare-scope",
    key="adls-access-key"
)

spark.conf.set(
    f"fs.azure.account.key.{storage_account_name}.dfs.core.windows.net",
    storage_account_key
)

silver_path = f"abfss://silver@{storage_account_name}.dfs.core.windows.net"
gold_path   = f"abfss://gold@{storage_account_name}.dfs.core.windows.net"

print("✅ Connected!")
print(f"Silver path: {silver_path}")
print(f"Gold path:   {gold_path}")

# COMMAND ----------

# Cell 2 - Read Silver Delta tables
df_patients       = spark.read.format("delta").load(f"{silver_path}/patients")
df_admissions     = spark.read.format("delta").load(f"{silver_path}/admissions")
df_diagnoses      = spark.read.format("delta").load(f"{silver_path}/diagnoses")
df_prescriptions  = spark.read.format("delta").load(f"{silver_path}/prescriptions")

print(f"✅ Patients:      {df_patients.count()} rows")
print(f"✅ Admissions:    {df_admissions.count()} rows")
print(f"✅ Diagnoses:     {df_diagnoses.count()} rows")
print(f"✅ Prescriptions: {df_prescriptions.count()} rows")

# COMMAND ----------

# Cell 3 - Gold: Patient Summary
from pyspark.sql.functions import (
    col, count, avg, min, max,
    round, sum, countDistinct, current_timestamp
)

gold_patient_summary = df_patients \
    .join(df_admissions, "subject_id", "left") \
    .groupBy(
        "subject_id",
        "gender",
        "dob",
        "is_deceased"
    ) \
    .agg(
        count("hadm_id").alias("total_admissions"),
        round(avg("los_days"), 2).alias("avg_los_days"),
        sum("los_days").alias("total_los_days"),
        min("admittime").alias("first_admission"),
        max("admittime").alias("last_admission"),
        sum(col("is_hospital_death").cast("integer")).alias("hospital_deaths")
    ) \
    .withColumn("gold_timestamp", current_timestamp())

print(f"✅ Gold Patient Summary: {gold_patient_summary.count()} rows")
gold_patient_summary.show(3, truncate=False)

# COMMAND ----------

# Cell 4 - Gold: 30-day Readmission Analysis
from pyspark.sql.functions import lag, datediff, when
from pyspark.sql.window import Window

window_readmit = Window \
    .partitionBy("subject_id") \
    .orderBy("admittime")

df_readmission = df_admissions \
    .withColumn("prev_dischtime",
        lag("dischtime", 1).over(window_readmit)
    ) \
    .withColumn("days_since_last_discharge",
        datediff(col("admittime"), col("prev_dischtime"))
    ) \
    .withColumn("is_readmission_30d",
        when(col("days_since_last_discharge") <= 30, True).otherwise(False)
    )

gold_readmission = df_readmission \
    .groupBy("admission_type") \
    .agg(
        count("hadm_id").alias("total_admissions"),
        sum(col("is_readmission_30d").cast("integer")).alias("readmissions_30d"),
        round(
            sum(col("is_readmission_30d").cast("integer")) * 100.0 / count("hadm_id"), 2
        ).alias("readmission_rate_pct")
    ) \
    .withColumn("gold_timestamp", current_timestamp())

print(f"✅ Gold Readmission Analysis: {gold_readmission.count()} rows")
gold_readmission.show(truncate=False)

# COMMAND ----------

# Cell 5 - Gold: Diagnosis Trends (fixed)
gold_diagnosis_trends = df_diagnoses \
    .join(df_admissions, "hadm_id", "left") \
    .groupBy("icd9_code", "is_primary_diagnosis") \
    .agg(
        count("hadm_id").alias("total_cases"),
        countDistinct(df_diagnoses["subject_id"]).alias("unique_patients"),
        round(avg("los_days"), 2).alias("avg_los_days")
    ) \
    .orderBy(col("total_cases").desc()) \
    .withColumn("gold_timestamp", current_timestamp())

print(f"✅ Gold Diagnosis Trends: {gold_diagnosis_trends.count()} rows")
gold_diagnosis_trends.show(5, truncate=False)

# COMMAND ----------

# Cell 6 - Gold: Medication Analysis
gold_medication = df_prescriptions \
    .groupBy("drug", "route", "drug_type") \
    .agg(
        count("hadm_id").alias("total_prescriptions"),
        countDistinct("subject_id").alias("unique_patients"),
        countDistinct("hadm_id").alias("unique_admissions"),
        round(avg("drug_days"), 2).alias("avg_drug_days")
    ) \
    .orderBy(col("total_prescriptions").desc()) \
    .withColumn("gold_timestamp", current_timestamp())

print(f"✅ Gold Medication Analysis: {gold_medication.count()} rows")
gold_medication.show(5, truncate=False)

# COMMAND ----------

# Cell 7 - Write all Gold tables
def write_gold(df, table_name):
    path = f"{gold_path}/{table_name}"
    df.write \
        .format("delta") \
        .mode("overwrite") \
        .option("overwriteSchema", "true") \
        .save(path)
    print(f"✅ Written: gold/{table_name} — {df.count()} rows")

write_gold(gold_patient_summary,    "patient_summary")
write_gold(gold_readmission,        "readmission_analysis")
write_gold(gold_diagnosis_trends,   "diagnosis_trends")
write_gold(gold_medication,         "medication_analysis")

print("\n🎉 All Gold tables written successfully!")

# COMMAND ----------

