# Databricks notebook source
sfOptions = {
    "sfURL": "IFDLYOS-UOA26006.snowflakecomputing.com",
    "sfUser": "PAWANCSE29",
    "sfPassword": dbutils.secrets.get(scope="healthcare-scope", key="snowflake-password"),
    "sfDatabase": "HEALTHCARE_DB",
    "sfSchema": "GOLD",
    "sfWarehouse": "HEALTHCARE_WH",
    "sfRole": "ACCOUNTADMIN"
}
print("✅ Snowflake config ready")

# COMMAND ----------

# Set ADLS access key
spark.conf.set(
    "fs.azure.account.key.healthcaredlspaw.dfs.core.windows.net",
    dbutils.secrets.get(scope="healthcare-scope", key="adls-access-key")
)

# Read Gold Delta tables
patient_summary = spark.read.format("delta")\
    .load("abfss://gold@healthcaredlspaw.dfs.core.windows.net/patient_summary")

readmission_analysis = spark.read.format("delta")\
    .load("abfss://gold@healthcaredlspaw.dfs.core.windows.net/readmission_analysis")

diagnosis_trends = spark.read.format("delta")\
    .load("abfss://gold@healthcaredlspaw.dfs.core.windows.net/diagnosis_trends")

medication_analysis = spark.read.format("delta")\
    .load("abfss://gold@healthcaredlspaw.dfs.core.windows.net/medication_analysis")

print("✅ All Gold Delta tables loaded")

# COMMAND ----------

def write_to_snowflake(df, table_name):
    df.write \
        .format("net.snowflake.spark.snowflake") \
        .options(**sfOptions) \
        .option("dbtable", table_name) \
        .mode("overwrite") \
        .save()
    print(f"✅ {table_name} written to Snowflake")

write_to_snowflake(patient_summary, "PATIENT_SUMMARY")
write_to_snowflake(readmission_analysis, "READMISSION_ANALYSIS")
write_to_snowflake(diagnosis_trends, "DIAGNOSIS_TRENDS")
write_to_snowflake(medication_analysis, "MEDICATION_ANALYSIS")

# COMMAND ----------

for table in ["PATIENT_SUMMARY", "READMISSION_ANALYSIS", "DIAGNOSIS_TRENDS", "MEDICATION_ANALYSIS"]:
    df = spark.read \
        .format("net.snowflake.spark.snowflake") \
        .options(**sfOptions) \
        .option("dbtable", table) \
        .load()
    print(f"✅ {table}: {df.count()} rows")