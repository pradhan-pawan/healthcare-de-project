# Databricks notebook source
# Cell 1 - Secure ADLS connection using Databricks Secrets
storage_account_name = "healthcaredlspaw"

# Securely fetch key from Databricks secret scope
storage_account_key = dbutils.secrets.get(
    scope="healthcare-scope",
    key="adls-access-key"
)

spark.conf.set(
    f"fs.azure.account.key.{storage_account_name}.dfs.core.windows.net",
    storage_account_key
)

bronze_path = f"abfss://bronze@{storage_account_name}.dfs.core.windows.net/processed"
silver_path = f"abfss://silver@{storage_account_name}.dfs.core.windows.net"

print("✅ ADLS connection configured securely!")
print(f"Bronze path: {bronze_path}")
print(f"Silver path: {silver_path}")

# COMMAND ----------

# Cell 2 - Read all Bronze Parquet files
from pyspark.sql.functions import col, when, lit, current_timestamp, row_number, trim, upper
from pyspark.sql.window import Window

# Read each table from bronze
df_patients      = spark.read.parquet(f"{bronze_path}/patients/")
df_admissions    = spark.read.parquet(f"{bronze_path}/admissions/")
df_diagnoses     = spark.read.parquet(f"{bronze_path}/diagnoses_icd/")
df_prescriptions = spark.read.parquet(f"{bronze_path}/prescriptions/")
df_icd_codes     = spark.read.parquet(f"{bronze_path}/d_icd_diagnoses/")

# Print schema + counts
print("=" * 50)
print(f"✅ Patients:      {df_patients.count()} rows")
print(f"✅ Admissions:    {df_admissions.count()} rows")
print(f"✅ Diagnoses:     {df_diagnoses.count()} rows")
print(f"✅ Prescriptions: {df_prescriptions.count()} rows")
print(f"✅ ICD Codes:     {df_icd_codes.count()} rows")
print("=" * 50)
print("\nPatients Schema:")
df_patients.printSchema()

# COMMAND ----------

# Cell 3 - Silver Patients (cleaning + deduplication)
from pyspark.sql.functions import (
    col, when, lit, current_timestamp, row_number,
    trim, upper, to_date, datediff, floor, regexp_replace
)
from pyspark.sql.window import Window

# Step 1 - Cast types + clean
df_patients_clean = df_patients \
    .withColumn("subject_id", col("subject_id").cast("integer")) \
    .withColumn("row_id", col("row_id").cast("integer")) \
    .withColumn("dob", to_date(col("dob"))) \
    .withColumn("dod", to_date(col("dod"))) \
    .withColumn("gender", trim(upper(col("gender")))) \
    .withColumn("expire_flag", col("expire_flag").cast("integer")) \
    .withColumn("is_deceased", when(col("expire_flag") == 1, True).otherwise(False)) \
    .withColumn("age_at_death",
        when(col("dod").isNotNull(),
            floor(datediff(col("dod"), col("dob")) / 365)
        ).otherwise(None)
    ) \
    .withColumn("silver_timestamp", current_timestamp())

# Step 2 - Deduplicate (keep latest by subject_id)
window_dedup = Window.partitionBy("subject_id").orderBy(col("row_id").desc())
df_patients_silver = df_patients_clean \
    .withColumn("rn", row_number().over(window_dedup)) \
    .filter(col("rn") == 1) \
    .drop("rn", "row_id", "ingestion_timestamp", "source_filename", "batch_id")

# Step 3 - Data quality check
total = df_patients_silver.count()
nulls = df_patients_silver.filter(col("subject_id").isNull()).count()
print(f"✅ Silver Patients: {total} rows")
print(f"✅ Null subject_ids: {nulls}")
df_patients_silver.printSchema()

# COMMAND ----------

# Cell 4 - Silver Admissions
from pyspark.sql.functions import to_timestamp, unix_timestamp

df_admissions_clean = df_admissions \
    .withColumn("subject_id",   col("subject_id").cast("integer")) \
    .withColumn("hadm_id",      col("hadm_id").cast("integer")) \
    .withColumn("row_id",       col("row_id").cast("integer")) \
    .withColumn("admittime",    to_timestamp(col("admittime"))) \
    .withColumn("dischtime",    to_timestamp(col("dischtime"))) \
    .withColumn("deathtime",    to_timestamp(col("deathtime"))) \
    .withColumn("admission_type",     trim(upper(col("admission_type")))) \
    .withColumn("admission_location", trim(upper(col("admission_location")))) \
    .withColumn("discharge_location", trim(upper(col("discharge_location")))) \
    .withColumn("insurance",    trim(upper(col("insurance")))) \
    .withColumn("marital_status", trim(upper(col("marital_status")))) \
    .withColumn("ethnicity",    trim(upper(col("ethnicity")))) \
    .withColumn("hospital_expire_flag", col("hospital_expire_flag").cast("integer")) \
    .withColumn("los_hours",
        floor((unix_timestamp(col("dischtime")) - unix_timestamp(col("admittime"))) / 3600)
    ) \
    .withColumn("los_days",
        floor((unix_timestamp(col("dischtime")) - unix_timestamp(col("admittime"))) / 86400)
    ) \
    .withColumn("is_hospital_death",
        when(col("hospital_expire_flag") == 1, True).otherwise(False)
    ) \
    .withColumn("silver_timestamp", current_timestamp())

# Deduplicate by hadm_id
window_dedup = Window.partitionBy("hadm_id").orderBy(col("row_id").desc())
df_admissions_silver = df_admissions_clean \
    .withColumn("rn", row_number().over(window_dedup)) \
    .filter(col("rn") == 1) \
    .drop("rn", "row_id", "ingestion_timestamp", "source_filename", "batch_id")

# Quality check
total   = df_admissions_silver.count()
nulls   = df_admissions_silver.filter(col("hadm_id").isNull()).count()
neg_los = df_admissions_silver.filter(col("los_hours") < 0).count()
print(f"✅ Silver Admissions: {total} rows")
print(f"✅ Null hadm_ids:     {nulls}")
print(f"✅ Negative LOS:      {neg_los}")
df_admissions_silver.show(3, truncate=False)

# COMMAND ----------

# Cell 5 - Silver Diagnoses
df_diagnoses_clean = df_diagnoses \
    .withColumn("subject_id", col("subject_id").cast("integer")) \
    .withColumn("hadm_id",    col("hadm_id").cast("integer")) \
    .withColumn("row_id",     col("row_id").cast("integer")) \
    .withColumn("seq_num",    col("seq_num").cast("integer")) \
    .withColumn("icd9_code",  trim(col("icd9_code"))) \
    .withColumn("is_primary_diagnosis",
        when(col("seq_num") == 1, True).otherwise(False)
    ) \
    .withColumn("silver_timestamp", current_timestamp())

# Deduplicate
window_dedup = Window.partitionBy("hadm_id", "icd9_code").orderBy(col("row_id").desc())
df_diagnoses_silver = df_diagnoses_clean \
    .withColumn("rn", row_number().over(window_dedup)) \
    .filter(col("rn") == 1) \
    .drop("rn", "row_id", "ingestion_timestamp", "source_filename", "batch_id")

# Quality check
total   = df_diagnoses_silver.count()
primary = df_diagnoses_silver.filter(col("is_primary_diagnosis") == True).count()
print(f"✅ Silver Diagnoses:        {total} rows")
print(f"✅ Primary diagnoses:       {primary} rows")
print(f"✅ Unique admissions:       {df_diagnoses_silver.select('hadm_id').distinct().count()}")
df_diagnoses_silver.show(3, truncate=False)

# COMMAND ----------

# Cell 6 - Silver Prescriptions
from pyspark.sql.functions import to_date, initcap

df_prescriptions_clean = df_prescriptions \
    .withColumn("subject_id",  col("subject_id").cast("integer")) \
    .withColumn("hadm_id",     col("hadm_id").cast("integer")) \
    .withColumn("row_id",      col("row_id").cast("integer")) \
    .withColumn("icustay_id",  col("icustay_id").cast("integer")) \
    .withColumn("startdate",   to_date(col("startdate"))) \
    .withColumn("enddate",     to_date(col("enddate"))) \
    .withColumn("drug",        trim(initcap(col("drug")))) \
    .withColumn("drug_type",   trim(upper(col("drug_type")))) \
    .withColumn("route",       trim(upper(col("route")))) \
    .withColumn("dose_val_rx", col("dose_val_rx").cast("double")) \
    .withColumn("drug_days",
        when(
            col("enddate").isNotNull() & col("startdate").isNotNull(),
            datediff(col("enddate"), col("startdate"))
        ).otherwise(None)
    ) \
    .withColumn("is_active",
        when(col("enddate").isNull(), True).otherwise(False)
    ) \
    .withColumn("silver_timestamp", current_timestamp()) \
    .filter(col("drug").isNotNull()) \
    .filter(col("hadm_id").isNotNull())

# Deduplicate
window_dedup = Window.partitionBy("hadm_id", "drug", "startdate") \
    .orderBy(col("row_id").desc())
df_prescriptions_silver = df_prescriptions_clean \
    .withColumn("rn", row_number().over(window_dedup)) \
    .filter(col("rn") == 1) \
    .drop("rn", "row_id", "ingestion_timestamp", "source_filename", "batch_id")

# Quality check
total        = df_prescriptions_silver.count()
null_drugs   = df_prescriptions_silver.filter(col("drug").isNull()).count()
unique_drugs = df_prescriptions_silver.select("drug").distinct().count()
print(f"✅ Silver Prescriptions: {total} rows")
print(f"✅ Null drugs:           {null_drugs}")
print(f"✅ Unique drugs:         {unique_drugs}")
df_prescriptions_silver.show(3, truncate=False)

# COMMAND ----------

# Cell 7 - Write all Silver tables to ADLS
def write_silver(df, table_name):
    path = f"{silver_path}/{table_name}"
    df.write \
        .format("delta") \
        .mode("overwrite") \
        .option("overwriteSchema", "true") \
        .save(path)
    print(f"✅ Written: silver/{table_name} — {df.count()} rows")

# Write all tables
write_silver(df_patients_silver,      "patients")
write_silver(df_admissions_silver,    "admissions")
write_silver(df_diagnoses_silver,     "diagnoses")
write_silver(df_prescriptions_silver, "prescriptions")

print("\n🎉 All Silver tables written successfully!")